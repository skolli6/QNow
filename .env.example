# ─── FIREBASE ───────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_fcm

# ─── WHATSAPP (Meta Cloud API) ──────────────────────────────
# Get free at: https://developers.facebook.com/docs/whatsapp/cloud-api
VITE_WHATSAPP_TOKEN=your_whatsapp_access_token
VITE_WHATSAPP_PHONE_ID=your_phone_number_id

# ─── SUPER ADMIN ────────────────────────────────────────────
# Change these before deploying!
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=QNow@2024!

# ─── APP ────────────────────────────────────────────────────
VITE_APP_URL=https://your-app.vercel.app
